{
    "event": "pending.accepted",
    "method": "POST",
    "url": "https://api.sendgrid.com/v3/mail/send",
    "headers": {
        "Authorization": "Bearer <SENDGRID_API_KEY>",
        "Content-Type": "application/json"
    },
    "query_params": {},
    "cookies": {},
    "body": {
        "personalizations": [
            {
                "to": [
                    { "email": "{{email}}" }
                ]
            }
        ],
        "from": {
            "email": "<SENDER_EMAIL>"
        },
        "subject": "Access Granted — {{service}}",
        "content": [
            {
                "type": "text/plain",
                "value": "Hello {{name}},{{nl}}{{nl}}Your access request for {{service}} has been approved.{{nl}}{{nl}}Access expires on {{expiry_date}} at {{expiry_time}}.{{nl}}{{nl}}— {{owner_name}}"
            }
        ]
    }
}
